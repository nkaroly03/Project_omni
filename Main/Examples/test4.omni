let SHIFT_COUNT: int = 32;

let value: int = 0x80ff0000;

print("value: ");
print(value);
print("\n");

let i: int = 32;
while ((i = i - 1) >= 0)
    print(value >> i & 1);
print("\n");

value = value >> SHIFT_COUNT & (1 << (32 - SHIFT_COUNT) % 32) - (1 + (SHIFT_COUNT % 32 == 0));

i = 32;
while ((i = i - 1) >= 0)
    print(value >> i & 1);
print("\n");
