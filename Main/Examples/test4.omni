let WIDTH: int = 128;
let HEIGHT: int = 32;

let frequency: float = 1;
if (argc > 0 and argv(0) > 0)
    frequency = argv(0);

let PI: float = 3.14159265;

/*/
    for (size_t y = 0; y <= HEIGHT; ++y){
        for (size_t x = 0; x <= WIDTH; ++x)
            putchar((HEIGHT / 2 - (int)y == (int)roundf(HEIGHT / 2.0f * sinf(2.0f * PI * x / WIDTH))) ? '*' : ' ');
        putchar('\n');
    }
/*/

for (0..HEIGHT + 1) |y|{
    for (0..WIDTH + 1)|x|{
        let sin: float = 2 * PI * frequency * x / WIDTH;
        {
            let k: int = 2 * sin / PI;
            sin = sin - k * PI / 2;

            let region: int = k % 4;
            if (region % 2 == 1)
                sin = PI / 2 - sin;
            sin = sin - sin ** 3 / 6 + sin ** 5 / 120;
            if (region > 1)
                sin = -sin;
        }

        sin = sin * HEIGHT / 2;
        if (sin >= 0){
            if (sin % 1 >= 0.5)
                sin = sin + 1;
        }
        else{
            if (sin % 1 < -0.5)
                sin = sin - 1;
        }

        let int_cast: int = sin;
        if (HEIGHT / 2 - y == int_cast)
            print("*");
        else
            print(" ");
    }
    print("\n");
}
