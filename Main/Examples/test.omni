let result: float = 0;

while (true){
    let op: int = 0;
    while ((op = scan(
        "Enter operation:\n"
        "\t[0] -> Add\n"
        "\t[1] -> Sub\n"
        "\t[2] -> Mul\n"
        "\t[3] -> Div\n"
        "\t[4] -> Mod\n"
        "\t[5] -> Quit\n\n"
        "Op: "
    )) < 0 or op > 5)
        print("Invalid operation\n");

    if (op != 5){
        let a: float = scan("a: ");
        let b: float = scan("b: ");
        
        let arithm_error: bool = false;

        if (op == 0)
            result = a + b;
        else if (op == 1)
            result = a - b;
        else if (op == 2)
            result = a * b;
        else if (b != 0){
            if (op == 3)
                result = a / b;
            else
                result = a % b;
        }
        else
            arithm_error = true;

        if (not arithm_error){
            print("result: ");
            print(result);
            print("\n");
        }
        else
            print("Arithmetic error\n");
    }
    else{
        print("Stopping\n");
        return result;
    }
}
