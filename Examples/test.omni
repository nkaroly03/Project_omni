let stop: bool = false;

while (not stop){
    let a: float = scan("a:");
    let b: float = scan("b:");

    print("0 -> Add");
    print("1 -> Sub");
    print("2 -> Mul");
    print("3 -> Div");
    print("4 -> Mod");
    print("5 -> Quit");

    let op: int = scan("");

    if (op >= 0 and op <= 5){
        if (op == 0){
            print("Result:");
            print(a + b);
        }
        else if (op == 1){
            print("Result:");
            print(a - b);
        }
        else if (op == 2){
            print("Result:");
            print(a * b);
        }
        else if (op == 3){
            if (b != 0){
                print("Result:");
                print(a / b);
            }
            else{
                print("Division by 0");
            }
        }
        else if (op == 4){
            if (b != 0){
                print("Result:");
                print(a % b);
            }
            else{
                print("Modulus by 0");
            }
        }
        else if (op == 5){
            stop = true;
        }
    }
    else{
        print("Invalid op");
    }
}
