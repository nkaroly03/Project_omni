let b: float = -3.14 + -a * (a + -a);

print("Hello");
print(b + 3.25);

let c44: int = scan("Input: ") + 1;

if (c44 < 10){
    let e: bool = not false;
    print("else if");
    print((c44 == 10) == (not (c44 != 10)));
}
else{
    let e: float = 2.718;
    print("c44 == 10");
}

while (c44 < 20){
    if (c44 % 2 == 0){
        print("Even");
    }
    else if (c44 % 2 == 1){
        print("Odd");
    }
    else{
        print("unreachable");
    }
    c44 = c44 + 1;
}
